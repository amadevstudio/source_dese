{
  "name": "source-dese",
  "version": "0.1.0",
  "description": "Standalone microservice that decodes minified JavaScript stack traces using sourcemaps",
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsoa spec-and-routes && esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external --loader:.json=json && cp src/generated/swagger.json dist/swagger.json",
    "start": "node dist/server.js",
    "dev": "tsoa spec-and-routes && nodemon --exec 'tsx src/server.ts'",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run --exclude e2e/",
    "test:e2e": "vitest run e2e/",
    "test:all": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "sourcemap",
    "stack-trace",
    "decode",
    "error-tracking",
    "debugging"
  ],
  "author": "Konstantin Smard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amadevstudio/source_dese.git"
  },
  "homepage": "https://github.com/amadevstudio/source_dese#readme",
  "bugs": {
    "url": "https://github.com/amadevstudio/source_dese/issues"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "express": "^5.1.0",
    "sourcemap-decode": "^0.1.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "zod": "^3.25.76"
  }
}
